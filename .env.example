# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env (contém segredos).

# Finnhub (grátis em https://finnhub.io/register) - usado para cotações, notícias e earnings
FINNHUB_API_KEY=

# Financial Modeling Prep (grátis em https://financialmodelingprep.com/developer/docs/)
# usado só para o calendário econômico (juros, payroll, inflação etc.)
FMP_API_KEY=

# Telegram - crie um bot com @BotFather no Telegram e pegue o token
TELEGRAM_BOT_TOKEN=
# Envie /start para o seu bot, depois rode `python get_chat_id.py` (veja README)
# para descobrir o TELEGRAM_CHAT_ID e cole aqui. Só esse chat_id poderá usar o bot.
TELEGRAM_CHAT_ID=

# Login da API (tokens JWT, ver app/auth.py). Gere com:
# python -c "import secrets; print(secrets.token_hex(32))"
# OBRIGATÓRIO em produção - sem isso, todo mundo perde a sessão a cada restart do servidor
# (a chave assina o JWT; trocar a chave invalida todos os tokens já emitidos).
SECRET_KEY=
# Quantas horas um token de login fica válido antes de precisar logar de novo.
JWT_EXPIRE_HOURS=168

# CORS - URL do front-end (React separado). Em produção, é a URL do site estático no Render.
FRONTEND_ORIGIN=http://localhost:5173

# Banco de dados (SQLite por padrão, funciona out-of-the-box)
DATABASE_URL=sqlite:///./nasdaq_monitor.db

# Frequência de polling (em segundos)
QUOTE_POLL_SECONDS=60
INDICATOR_REFRESH_SECONDS=300
DAILY_SUMMARY_HOUR_UTC=21
NEWS_REFRESH_SECONDS=1800
CALENDAR_REFRESH_HOUR_UTC=6

# Assistente com IA - opcional: sem chave configurada, o sistema funciona normal
# (resumo diário em formato simples, assistente avisa que está desativado).
#
# LLM_PROVIDER escolhe qual API usar:
#   "groq"      -> grátis, sem cartão de crédito, modelos Llama bem rápidos
#                  (crie a key em https://console.groq.com/keys)
#   "gemini"    -> grátis, sem cartão de crédito
#                  (crie a key em https://aistudio.google.com/apikey)
#   "anthropic" -> pago (créditos pré-pagos), recomendado pra produção
#                  (crie a key em https://console.anthropic.com)
LLM_PROVIDER=groq

# Usado só se LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Usado só se LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Usado só se LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# Resumo diário narrativo (em vez de só lista de números) - true/false
LLM_DAILY_NARRATIVE_ENABLED=true
# Adiciona uma frase de contexto de IA em CADA alerta disparado - desligado por padrão
# porque alertas podem disparar com frequência e cada um vira uma chamada de API.
LLM_ENRICH_ALERTS=false
