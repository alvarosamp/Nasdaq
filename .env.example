# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env (contém segredos).

# Finnhub (grátis em https://finnhub.io/register) - usado para cotações, notícias e earnings
FINNHUB_API_KEY=

# Financial Modeling Prep (grátis em https://financialmodelingprep.com/developer/docs/)
# usado só para o calendário econômico (juros, payroll, inflação etc.)
FMP_API_KEY=

# Telegram - crie um bot com @BotFather no Telegram e pegue o token
TELEGRAM_BOT_TOKEN=
# Envie /start para o seu bot, depois rode `python get_chat_id.py` (veja README)
# para descobrir o TELEGRAM_CHAT_ID e cole aqui. Só esse chat_id poderá usar o bot.
TELEGRAM_CHAT_ID=

# Login do dashboard web (sessão de verdade, com tela de cadastro/login).
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# OBRIGATÓRIO em produção - sem isso, todo mundo é deslogado a cada restart do servidor.
SECRET_KEY=
# Deixe "true" quando o site estiver atrás de HTTPS (ex: Render em produção).
# Em "true" localmente sem HTTPS, o cookie de sessão não funciona.
SESSION_COOKIE_SECURE=false

# Banco de dados (SQLite por padrão, funciona out-of-the-box)
DATABASE_URL=sqlite:///./nasdaq_monitor.db

# Frequência de polling (em segundos)
QUOTE_POLL_SECONDS=60
INDICATOR_REFRESH_SECONDS=300
DAILY_SUMMARY_HOUR_UTC=21
NEWS_REFRESH_SECONDS=1800
CALENDAR_REFRESH_HOUR_UTC=6
